{
  "name": "gtc",
  "version": "0.3.0",
  "private": true,
  "description": "ghostty configuration CLI tool",
  "bin": {
    "gtc": "./bin/gtc"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "oxlint --type-aware",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "clipboardy": "^5.3.1",
    "defu": "^6.1.7",
    "ofetch": "^1.5.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.12",
    "@types/yargs": "^17.0.35",
    "husky": "^9.1.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript": "6.0.2"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  },
  "packageManager": "bun@1.3.13"
}
